page {
  background:
    radial-gradient(circle at 15% -10%, #d8ecff 0, #eef5ff 35%, #f5f7fb 70%),
    #f5f7fb;
  color: #152238;
  font-size: 28rpx;
  font-family: "Avenir Next", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.container {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.hero {
  background: linear-gradient(135deg, #0f2a56 0%, #1d4f91 70%, #2e7ec8 100%);
  border-radius: 24rpx;
  padding: 26rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 16rpx 34rpx rgba(15, 42, 86, 0.28);
}

.hero-title {
  color: #f8fbff;
  font-size: 36rpx;
  font-weight: 700;
}

.hero-sub {
  margin-top: 8rpx;
  color: rgba(248, 251, 255, 0.88);
  line-height: 1.6;
  font-size: 24rpx;
}

.chip-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #eff7ff;
}

.card {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(182, 206, 236, 0.6);
  border-radius: 18rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 10rpx 24rpx rgba(39, 78, 120, 0.08);
  backdrop-filter: blur(4rpx);
}

.form-block {
  background: #f8fbff;
  border: 1rpx solid #d3e2f4;
  border-radius: 14rpx;
  padding: 14rpx;
  margin-top: 10rpx;
}

.field {
  margin-bottom: 10rpx;
}

.field-label {
  font-size: 24rpx;
  color: #345375;
  margin-bottom: 8rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
  color: #13243f;
}

.sub {
  color: #4d6079;
  line-height: 1.65;
  font-size: 24rpx;
}

.section-title {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #1e3f6f;
  font-weight: 600;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.stat {
  background: linear-gradient(145deg, #f7fbff 0%, #e9f2ff 100%);
  border: 1rpx solid #c9ddf6;
  border-radius: 14rpx;
  padding: 16rpx;
}

.stat-num {
  margin-top: 8rpx;
  font-size: 44rpx;
  color: #0e5ea8;
  font-weight: 700;
}

.input,
.textarea,
.picker {
  border: 1rpx solid #c9d9ef;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  margin-bottom: 12rpx;
  background: #fdfefe;
  color: #10223b;
  box-sizing: border-box;
  font-size: 28rpx;
}

.input,
.picker {
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 20rpx;
}

.textarea {
  min-height: 180rpx;
  line-height: 1.65;
  padding: 16rpx 20rpx;
}

.btn-primary,
.btn-ghost,
.btn-danger {
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
}

.btn-primary {
  background: linear-gradient(135deg, #0d7dd9 0%, #0d64bd 100%);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(13, 100, 189, 0.26);
}

.btn-ghost {
  background: #edf3fb;
  color: #1f3e66;
  border: 1rpx solid #c7d8ee;
}

.btn-danger {
  background: linear-gradient(135deg, #d94b4b 0%, #b23333 100%);
  color: #fff;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.row-2col {
  display: flex;
  gap: 12rpx;
}

.row-2col .input {
  flex: 1;
  margin-bottom: 0;
}

.row-2col .picker {
  flex: 1;
  margin-bottom: 0;
}

.action-bar {
  position: sticky;
  bottom: 14rpx;
  z-index: 20;
  padding-top: 8rpx;
}

.action-bar .btn-primary {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  font-size: 30rpx;
}

.list-item {
  border: 1rpx solid #d7e4f5;
  border-radius: 14rpx;
  padding: 14rpx;
  margin-top: 12rpx;
  background: #fbfdff;
}

.badge {
  background: #deedff;
  color: #16457a;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.kv {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6rpx 0;
}

.kv-key {
  color: #5a6f8e;
  font-size: 24rpx;
}

.kv-value {
  color: #143055;
  font-size: 24rpx;
  font-weight: 600;
}

.mt-8 {
  margin-top: 8rpx;
}

.mt-12 {
  margin-top: 12rpx;
}

.mt-20 {
  margin-top: 20rpx;
}
