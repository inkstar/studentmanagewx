page {
  background:
    radial-gradient(circle at 10% -20%, #e7eaff 0%, #f5f7ff 36%, #f8fafc 72%),
    #f8fafc;
  color: #111827;
  font-size: 28rpx;
  font-family: "SF Pro Display", "Avenir Next", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.container {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.hero {
  background: linear-gradient(135deg, #4f46e5 0%, #6366f1 58%, #8b5cf6 100%);
  border-radius: 26rpx;
  padding: 28rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 16rpx 38rpx rgba(99, 102, 241, 0.32);
}

.hero-title {
  color: #f8fbff;
  font-size: 36rpx;
  font-weight: 700;
}

.hero-sub {
  margin-top: 8rpx;
  color: rgba(248, 251, 255, 0.94);
  line-height: 1.6;
  font-size: 24rpx;
}

.chip-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.24);
  color: #eff7ff;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
}

.card {
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(208, 216, 240, 0.78);
  border-radius: 20rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 12rpx 28rpx rgba(99, 102, 241, 0.08);
  backdrop-filter: blur(4rpx);
}

.form-block {
  background: #f9fbff;
  border: 1rpx solid #dde5fb;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-top: 10rpx;
}

.field {
  margin-bottom: 10rpx;
}

.field-label {
  font-size: 24rpx;
  color: #4b5563;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
  color: #13243f;
}

.sub {
  color: #64748b;
  line-height: 1.65;
  font-size: 24rpx;
}

.section-title {
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 700;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.stat {
  background: linear-gradient(145deg, #f6f7ff 0%, #eef2ff 100%);
  border: 1rpx solid #d6ddfb;
  border-radius: 16rpx;
  padding: 16rpx;
}

.stat-num {
  margin-top: 8rpx;
  font-size: 44rpx;
  color: #4f46e5;
  font-weight: 700;
}

.input,
.textarea,
.picker {
  border: 1rpx solid #d6dcf5;
  border-radius: 14rpx;
  padding: 14rpx 16rpx;
  margin-bottom: 12rpx;
  background: #ffffff;
  color: #1f2937;
  box-sizing: border-box;
  font-size: 28rpx;
}

.input,
.picker {
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 20rpx;
}

.textarea {
  min-height: 180rpx;
  line-height: 1.65;
  padding: 16rpx 20rpx;
}

.textarea-lg {
  min-height: 220rpx;
}

.textarea-md {
  min-height: 160rpx;
}

.btn-primary,
.btn-ghost,
.btn-danger {
  border-radius: 16rpx;
  padding: 14rpx 16rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
  color: #fff;
  box-shadow: 0 10rpx 24rpx rgba(79, 70, 229, 0.28);
}

.btn-ghost {
  background: #eef2ff;
  color: #4338ca;
  border: 1rpx solid #cfd6fb;
}

.btn-danger {
  background: linear-gradient(135deg, #fb7185 0%, #f43f5e 100%);
  color: #fff;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.row-2col {
  display: flex;
  gap: 12rpx;
}

.row-2col .input {
  flex: 1;
  margin-bottom: 0;
}

.row-2col .picker {
  flex: 1;
  margin-bottom: 0;
}

.action-bar {
  position: sticky;
  bottom: 14rpx;
  z-index: 20;
  padding-top: 8rpx;
}

.action-bar .btn-primary {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  font-size: 30rpx;
}

.list-item {
  border: 1rpx solid #dde3f8;
  border-radius: 16rpx;
  padding: 14rpx;
  margin-top: 12rpx;
  background: #fcfdff;
}

.badge {
  background: #eef2ff;
  color: #4338ca;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.kv {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6rpx 0;
}

.kv-key {
  color: #6b7280;
  font-size: 24rpx;
}

.kv-value {
  color: #312e81;
  font-size: 24rpx;
  font-weight: 700;
}

.mt-8 {
  margin-top: 8rpx;
}

.mt-12 {
  margin-top: 12rpx;
}

.mt-20 {
  margin-top: 20rpx;
}
