page {
  background: #f5f7fb;
  color: #0f172a;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.sub {
  color: #475569;
  line-height: 1.6;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.stat {
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 16rpx;
}

.stat-num {
  font-size: 40rpx;
  color: #0284c7;
  font-weight: 700;
}
