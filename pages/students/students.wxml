<view class="container">
  <view class="hero">
    <view class="hero-title">学生台账</view>
    <view class="hero-sub">按年级管理学生信息与学习轨迹，支持批量导入。</view>
    <view class="chip-row">
      <view class="chip">总人数 {{students.length}}</view>
      <view class="chip">新增默认年级 {{currentGrade}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">搜索与筛选</view>
    <input class="input" placeholder="搜索姓名 / 年级 / 手机号" value="{{keyword}}" bindinput="onKeywordInput" />
    <picker mode="selector" range="{{gradeFilterOptions}}" value="{{filterGradeIndex}}" bindchange="onFilterGradeChange">
      <view class="picker">筛选年级：{{gradeFilterOptions[filterGradeIndex]}}</view>
    </picker>
  </view>

  <view class="card" wx:if="{{canAddStudent}}">
    <view class="section-title">新增学生</view>
    <view class="form-block">
      <view class="field">
        <view class="field-label">姓名</view>
        <input class="input" placeholder="学生姓名" data-key="name" value="{{form.name}}" bindinput="onFormInput" />
      </view>
      <view class="field">
        <view class="field-label">年级</view>
        <picker mode="selector" range="{{grades}}" value="{{gradeIndex}}" bindchange="onGradeChange">
          <view class="picker">{{currentGrade}}</view>
        </picker>
      </view>
      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">手机号</view>
          <input class="input" placeholder="选填" data-key="phone" value="{{form.phone}}" bindinput="onFormInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">家长称呼</view>
          <input class="input" placeholder="选填" data-key="guardian" value="{{form.guardian}}" bindinput="onFormInput" />
        </view>
      </view>
    </view>
    <view class="btn-primary" bindtap="addStudent">保存学生</view>
  </view>

  <view class="card" wx:if="{{canAddStudent}}">
    <view class="section-title">批量导入</view>
    <view class="sub">每行格式：姓名,年级,手机号,家长。年级为空时默认使用当前新增年级。</view>
    <textarea class="textarea mt-12" placeholder="张三,七年级,13800000000,张妈妈" value="{{importText}}" bindinput="onImportTextInput" />
    <view class="row">
      <view class="btn-ghost" bindtap="copyImportTemplate">复制模板</view>
      <view class="btn-primary" bindtap="importStudentsByCSV">执行导入</view>
    </view>
  </view>

  <view class="card" wx:else>
    <view class="section-title">录入权限</view>
    <view class="sub">当前角色为老师，仅管理员可新增和批量导入学生。</view>
  </view>

  <view class="card">
    <view class="section-title">学生列表（{{students.length}}）</view>
    <view wx:if="{{!students.length}}" class="sub">暂无数据</view>
    <view wx:for="{{students}}" wx:key="id" class="list-item" bindtap="toStudentDetail" data-id="{{item.id}}">
      <view class="row">
        <view>
          <view class="title" style="font-size: 28rpx; margin-bottom: 6rpx;">{{item.name}}</view>
          <view class="sub">{{item.grade}} · {{item.phone || '未填写手机号'}}</view>
        </view>
        <view class="badge">详情</view>
      </view>
      <view class="sub mt-8">课堂 {{item.lessonCount}} 次 · 进度 {{item.examCount}} 次</view>
    </view>
  </view>
</view>
