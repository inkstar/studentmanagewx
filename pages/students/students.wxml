<view class="container student-page" wx:if="{{!showCreatePanel}}">
  <view class="student-header">
    <view class="student-title">学生管理</view>
    <view class="header-actions">
      <view class="header-icon" bindtap="exportStudents">导</view>
      <view class="header-icon primary" wx:if="{{canManage}}" bindtap="startCreate">+</view>
    </view>
  </view>

  <view class="search-row">
    <input class="search-input" placeholder="搜索学生姓名、班主任或电话..." value="{{searchTerm}}" bindinput="onSearchInput" />
    <view class="filter-btn {{(filters.grade !== '全部' || filters.type !== '全部' || filters.status !== '全部') ? 'active' : ''}}" bindtap="openFilterPanel">筛</view>
  </view>

  <view class="active-filters" wx:if="{{filters.grade !== '全部' || filters.type !== '全部' || filters.status !== '全部'}}">
    <view class="filter-chip" wx:if="{{filters.grade !== '全部'}}">{{filters.grade}}</view>
    <view class="filter-chip" wx:if="{{filters.type !== '全部'}}">{{filters.type}}</view>
    <view class="filter-chip" wx:if="{{filters.status !== '全部'}}">{{filters.status}}</view>
    <view class="clear-link" bindtap="resetFilters">清除全部</view>
  </view>

  <view class="result-tip">{{filteredStudents.length > 0 ? ('找到 ' + filteredStudents.length + ' 位学生') : '未发现学生'}}</view>

  <view class="student-card" wx:for="{{filteredStudents}}" wx:key="id" bindtap="toStudentDetail" data-id="{{item.id}}">
    <view class="row top-row">
      <view class="row left-main" style="justify-content:flex-start;">
        <view class="avatar">{{item.avatar}}</view>
        <view>
          <view class="name">{{item.name}}</view>
          <view class="row tags" style="justify-content:flex-start;">
            <text class="tag grade">{{item.grade}}</text>
            <text class="tag type">{{item.classType || '1v1'}}</text>
            <text class="tag status {{item.status === '重点关注' ? 'danger' : ''}}">{{item.status}}</text>
          </view>
        </view>
      </view>
      <view class="progress-block">
        <view class="progress-num">{{item.progressPercent}}%</view>
        <view class="progress-track"><view class="progress-fill" style="width: {{item.progressPercent}}%;"></view></view>
      </view>
    </view>

    <view class="weak-tags" wx:if="{{item.weakTags.length}}">
      <text class="weak-pill" wx:for="{{item.weakTags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
    </view>
    <view class="weak-empty" wx:else>暂无薄弱标签</view>

    <view class="op-row" wx:if="{{canManage}}">
      <view class="op-btn op-view" catchtap="toStudentDetail" data-id="{{item.id}}">查看</view>
      <view class="op-btn op-edit" catchtap="startEdit" data-id="{{item.id}}">编辑</view>
      <view class="op-btn op-del" catchtap="deleteStudent" data-id="{{item.id}}" data-name="{{item.name}}">删除</view>
    </view>
  </view>

  <view class="empty" wx:if="{{!filteredStudents.length}}">
    <view class="empty-icon">学生</view>
    <view class="empty-text">暂无学生数据</view>
  </view>

  <view class="fab" wx:if="{{canManage}}" bindtap="startCreate">+</view>

  <view class="mask" wx:if="{{isFilterOpen}}" bindtap="closeFilterPanel">
    <view class="filter-panel" catchtap="stopTap">
      <view class="panel-title">筛选条件</view>

      <view class="filter-group">
        <view class="group-title">年级</view>
        <view class="option-wrap">
          <view class="option {{tempFilters.grade === '全部' ? 'active' : ''}}" bindtap="setTempGrade" data-value="全部">全部</view>
          <view class="option {{tempFilters.grade === item ? 'active' : ''}}" wx:for="{{grades}}" wx:key="*this" bindtap="setTempGrade" data-value="{{item}}">{{item}}</view>
        </view>
      </view>

      <view class="filter-group">
        <view class="group-title">班型</view>
        <view class="option-wrap">
          <view class="option {{tempFilters.type === '全部' ? 'active' : ''}}" bindtap="setTempType" data-value="全部">全部</view>
          <view class="option {{tempFilters.type === item ? 'active' : ''}}" wx:for="{{classTypes}}" wx:key="*this" bindtap="setTempType" data-value="{{item}}">{{item}}</view>
        </view>
      </view>

      <view class="filter-group">
        <view class="group-title">状态</view>
        <view class="option-wrap">
          <view class="option {{tempFilters.status === item ? 'active' : ''}}" wx:for="{{statusOptions}}" wx:key="*this" bindtap="setTempStatus" data-value="{{item}}">{{item}}</view>
        </view>
      </view>

      <view class="panel-actions">
        <view class="btn-ghost panel-btn" bindtap="resetFilters">重置</view>
        <view class="btn-primary panel-btn" bindtap="applyFilterPanel">应用筛选</view>
      </view>
    </view>
  </view>
</view>

<view class="container" wx:if="{{showCreatePanel && canManage}}">
  <view class="hero">
    <view class="hero-title">{{isEditMode ? '编辑学生' : '新增学生'}}</view>
    <view class="hero-sub">录入学生档案与联系方式，支持薄弱知识点标签。</view>
  </view>

  <view class="card">
    <view class="row">
      <view class="section-title" style="margin-bottom:0;">学生信息</view>
      <view class="btn-ghost action-btn" bindtap="toggleCreatePanel">返回清单</view>
    </view>

    <view class="form-block mt-12">
      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">姓名</view>
          <input class="input" placeholder="学生姓名" data-key="name" value="{{form.name}}" bindinput="onFormInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">年级</view>
          <picker mode="selector" range="{{grades}}" value="{{gradeIndex}}" bindchange="onGradeChange">
            <view class="picker">{{currentGrade}}</view>
          </picker>
        </view>
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">班型</view>
          <picker mode="selector" range="{{classTypes}}" value="{{classTypeIndex}}" bindchange="onClassTypeChange">
            <view class="picker">{{currentClassType}}</view>
          </picker>
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">班主任</view>
          <input class="input" placeholder="班主任姓名" data-key="homeroomTeacher" value="{{form.homeroomTeacher}}" bindinput="onFormInput" />
        </view>
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">学生电话</view>
          <input class="input" placeholder="选填" data-key="phone" value="{{form.phone}}" bindinput="onFormInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">家长电话</view>
          <input class="input" placeholder="选填" data-key="parentPhone" value="{{form.parentPhone}}" bindinput="onFormInput" />
        </view>
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">邮箱</view>
          <input class="input" placeholder="选填" data-key="email" value="{{form.email}}" bindinput="onFormInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">家长称呼</view>
          <input class="input" placeholder="选填" data-key="guardian" value="{{form.guardian}}" bindinput="onFormInput" />
        </view>
      </view>

      <view class="field">
        <view class="field-label">地址</view>
        <input class="input" placeholder="选填" data-key="address" value="{{form.address}}" bindinput="onFormInput" />
      </view>

      <view class="field">
        <view class="field-label">薄弱知识点（逗号分隔）</view>
        <input class="input" placeholder="如：函数单调性,三角函数" data-key="weakTopicsText" value="{{form.weakTopicsText}}" bindinput="onFormInput" />
      </view>

      <view class="field">
        <view class="field-label">备注</view>
        <textarea class="textarea textarea-md" placeholder="备注信息" data-key="notes" value="{{form.notes}}" bindinput="onFormInput" />
      </view>
    </view>

    <view class="btn-primary" bindtap="saveStudent">{{isEditMode ? '保存修改' : '保存学生'}}</view>
  </view>

  <view class="card">
    <view class="section-title">批量导入</view>
    <view class="sub">每行格式：姓名,年级,班型,班主任,学生电话,家长电话,家长称呼,薄弱知识点</view>
    <textarea class="textarea mt-12" placeholder="张三,七年级,1v1,王老师,13800000000,13900000000,张妈妈,函数单调性;二次函数" value="{{importText}}" bindinput="onImportTextInput" />
    <view class="row">
      <view class="btn-ghost" bindtap="copyImportTemplate">复制模板</view>
      <view class="btn-primary" bindtap="importStudentsByCSV">执行导入</view>
    </view>
  </view>
</view>
