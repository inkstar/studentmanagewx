.table-filters {
  display: flex;
  gap: 12rpx;
}

.table-filters .input {
  flex: 1;
  margin-bottom: 0;
}

.filter-picker {
  min-width: 180rpx;
  margin-bottom: 0;
}

.action-btn {
  height: 66rpx;
  line-height: 66rpx;
  padding: 0 20rpx;
}

.table-wrap {
  margin-top: 14rpx;
  border: 1rpx solid #d8def9;
  border-radius: 18rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 8rpx 20rpx rgba(79, 70, 229, 0.08);
}

.table-head {
  background: linear-gradient(90deg, #1f2937 0%, #111827 100%);
  color: #fff;
  padding: 16rpx 14rpx;
  font-weight: 700;
}

.table-row {
  align-items: flex-start;
  padding: 16rpx 14rpx;
  border-top: 1rpx solid #eef2ff;
  font-size: 24rpx;
  background: #ffffff;
}

.col-name {
  width: 13%;
}

.col-grade {
  width: 11%;
}

.col-class {
  width: 11%;
}

.col-head {
  width: 14%;
  color: #2d415d;
}

.col-weak {
  width: 32%;
  color: #2d415d;
}

.col-action {
  width: 19%;
}

.grade-pill {
  display: inline-block;
  border-radius: 10rpx;
  padding: 6rpx 12rpx;
  background: #2563eb;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

.class-pill {
  display: inline-block;
  border-radius: 10rpx;
  padding: 6rpx 12rpx;
  background: #16a34a;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

.weak-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.weak-pill {
  display: inline-block;
  border-radius: 10rpx;
  padding: 4rpx 10rpx;
  background: #facc15;
  color: #111827;
  font-size: 20rpx;
  font-weight: 600;
}

.op-row {
  display: flex;
  gap: 8rpx;
  justify-content: flex-end;
}

.op-btn {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 10rpx;
  border: 1rpx solid;
  font-size: 22rpx;
  font-weight: 700;
  background: #fff;
}

.op-view {
  color: #00a8f0;
  border-color: #00a8f0;
}

.op-edit {
  color: #2563eb;
  border-color: #2563eb;
}

.op-del {
  color: #ef4444;
  border-color: #ef4444;
}
