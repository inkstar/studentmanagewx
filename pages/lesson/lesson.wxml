<view class="container">
  <view class="hero">
    <view class="hero-title">课程记录</view>
    <view class="hero-sub">记录上课信息、课程状态、出勤与课堂评语。</view>
    <view class="chip-row">
      <view class="chip">班级 {{currentClassName}}</view>
      <view class="chip">学生 {{students.length}}</view>
    </view>
  </view>

  <view class="card" wx:if="{{fatalError}}">
    <view class="section-title">页面错误</view>
    <view class="sub">{{fatalError}}</view>
  </view>

  <view class="card">
    <view class="section-title">课程信息</view>
    <view class="form-block">
      <view class="field">
        <view class="field-label">班级</view>
        <picker mode="selector" range="{{classes}}" range-key="name" value="{{classIndex}}" bindchange="onClassChange">
          <view class="picker">{{currentClassName}}</view>
        </picker>
      </view>

      <view class="field">
        <view class="field-label">上课日期</view>
        <input class="input" placeholder="如 2026-03-03" value="{{lessonDate}}" bindinput="onDateInput" />
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">科目</view>
          <input class="input" placeholder="如 数学" value="{{subject}}" bindinput="onSubjectInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">授课老师</view>
          <input class="input" placeholder="老师姓名" value="{{teacher}}" bindinput="onTeacherInput" />
        </view>
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">时长（分钟）</view>
          <input class="input" type="number" placeholder="120" value="{{duration}}" bindinput="onDurationInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">课程状态</view>
          <picker mode="selector" range="{{lessonStatusOptions}}" value="{{lessonStatusIndex}}" bindchange="onStatusChange">
            <view class="picker">{{lessonStatusOptions[lessonStatusIndex]}}</view>
          </picker>
        </view>
      </view>

      <view class="field">
        <view class="field-label">课程内容</view>
        <input class="input" placeholder="本节课重点内容" value="{{content}}" bindinput="onContentInput" />
      </view>

      <view class="field">
        <view class="field-label">课后作业</view>
        <input class="input" placeholder="课后练习与作业安排" value="{{homework}}" bindinput="onHomeworkInput" />
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">学生出勤与评语</view>
    <view wx:if="{{!students.length}}" class="sub">当前班级暂无学生</view>

    <view wx:for="{{students}}" wx:key="id" class="list-item">
      <view class="row">
        <text>{{item.name}}</text>
        <picker mode="selector" range="{{attendanceOptions}}" value="{{records[index].attendanceIndex}}" bindchange="onAttendanceChange" data-index="{{index}}">
          <view class="badge">{{records[index].attendance}}</view>
        </picker>
      </view>
      <input class="input mt-12" placeholder="课堂评语（选填）" value="{{records[index].comment}}" bindinput="onCommentInput" data-index="{{index}}" />
    </view>
  </view>

  <view class="action-bar">
    <view class="btn-primary" bindtap="saveLesson">保存课程记录</view>
  </view>
</view>
