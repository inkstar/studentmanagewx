<view class="container" wx:if="{{!showCreatePanel}}">
  <view class="record-header">
    <view class="record-title">课程记录</view>
    <view class="search-dot">搜</view>
  </view>
  <view class="record-time">最后更新: {{updatedAt}}</view>

  <view class="search-box mt-12">
    <input class="input search-input" placeholder="搜索学生/老师/课程内容" value="{{lessonKeyword}}" bindinput="onLessonKeywordInput" />
    <view class="btn-ghost export-btn" bindtap="exportLessons">导出</view>
  </view>

  <view class="tabs-row">
    <view class="tab-item {{subjectTabIndex === 0 ? 'active' : ''}}" bindtap="onSubjectTabTap" data-index="0">全部</view>
    <view class="tab-item {{subjectTabIndex === 1 ? 'active' : ''}}" bindtap="onSubjectTabTap" data-index="1">数学</view>
    <view class="tab-item {{subjectTabIndex === 2 ? 'active' : ''}}" bindtap="onSubjectTabTap" data-index="2">物理</view>
    <view class="tab-item {{subjectTabIndex === 3 ? 'active' : ''}}" bindtap="onSubjectTabTap" data-index="3">本周</view>
  </view>

  <view class="empty" wx:if="{{!filteredLessons.length}}">
    <view class="empty-icon">课</view>
    <view class="empty-text">暂无课程记录</view>
  </view>

  <view wx:for="{{filteredLessons}}" wx:key="id" class="record-card">
    <view class="row card-top">
      <view class="row card-left" style="justify-content:flex-start;">
        <view class="avatar">{{item.studentAvatarLetter}}</view>
        <view>
          <view class="row" style="justify-content:flex-start; gap:8rpx;">
            <view class="student-name">{{item.studentName}}</view>
            <view class="subject-badge {{item.subject === '数学' ? 'math' : 'other'}}">{{item.subject}}</view>
          </view>
          <view class="time-line">{{item.grade || '-'}} · {{item.lessonDate}} · {{item.timeRange}}</view>
        </view>
      </view>
      <view class="status-badge">{{item.status}}</view>
    </view>

    <view class="content-line">{{item.contentSummary || '未填写课程内容'}}</view>

    <view class="op-row">
      <view class="icon-btn edit" bindtap="startEdit" data-id="{{item.id}}">✎</view>
      <view class="icon-btn copy" bindtap="copyLesson" data-id="{{item.id}}">⧉</view>
      <view class="icon-btn view" bindtap="viewLesson" data-id="{{item.id}}">v</view>
      <view class="icon-btn img" bindtap="exportLessonImage" data-id="{{item.id}}">🖼</view>
      <view class="icon-btn del" bindtap="deleteLesson" data-id="{{item.id}}">🗑</view>
    </view>
  </view>

  <view class="fab" bindtap="startCreate">+</view>
</view>

<view class="container" wx:if="{{showCreatePanel}}">
  <view class="hero">
    <view class="hero-title">{{isEditMode ? '编辑课程记录' : '新增课程记录'}}</view>
    <view class="hero-sub">可修改后保存，或复制旧记录快速新建。</view>
  </view>

  <view class="card">
    <view class="row">
      <view class="section-title" style="margin-bottom:0;">课程信息</view>
      <view class="btn-ghost action-btn" bindtap="toggleCreatePanel">返回列表</view>
    </view>

    <view class="form-block mt-12">
      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">年级</view>
          <picker mode="selector" range="{{grades}}" value="{{gradeIndex}}" bindchange="onGradeChange">
            <view class="picker">{{currentGrade}}</view>
          </picker>
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">学生</view>
          <picker mode="selector" range="{{students}}" range-key="name" value="{{studentIndex}}" bindchange="onStudentChange">
            <view class="picker">{{currentStudentName}}</view>
          </picker>
        </view>
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">上课日期</view>
          <input class="input" placeholder="如 2026-03-04" value="{{lessonDate}}" bindinput="onDateInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">科目</view>
          <input class="input" placeholder="默认数学" value="{{subject}}" bindinput="onSubjectInput" />
        </view>
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">开始时间</view>
          <input class="input" placeholder="19:00" value="{{startTime}}" bindinput="onStartTimeInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">结束时间</view>
          <input class="input" placeholder="21:00" value="{{endTime}}" bindinput="onEndTimeInput" />
        </view>
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">授课老师</view>
          <input class="input" placeholder="老师姓名" value="{{teacher}}" bindinput="onTeacherInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">时长（分钟）</view>
          <input class="input" type="number" placeholder="120" value="{{duration}}" bindinput="onDurationInput" />
        </view>
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">课程状态</view>
          <picker mode="selector" range="{{lessonStatusOptions}}" value="{{lessonStatusIndex}}" bindchange="onStatusChange">
            <view class="picker">{{lessonStatusOptions[lessonStatusIndex]}}</view>
          </picker>
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">出勤状态</view>
          <picker mode="selector" range="{{attendanceOptions}}" value="{{attendanceIndex}}" bindchange="onAttendanceChange">
            <view class="picker">{{attendance}}</view>
          </picker>
        </view>
      </view>

      <view class="field">
        <view class="field-label">课程内容（支持 Markdown）</view>
        <textarea class="textarea textarea-xl editor-area" placeholder="记录教学内容、重点难点、授课方法..." value="{{content}}" bindinput="onContentInput" />
      </view>

      <view class="field">
        <view class="field-label">学生情况（支持 Markdown）</view>
        <textarea class="textarea textarea-xl editor-area" placeholder="记录课堂表现、掌握情况、问题点..." value="{{studentPerformance}}" bindinput="onPerformanceInput" />
      </view>

      <view class="field">
        <view class="field-label">课后作业（支持 Markdown）</view>
        <textarea class="textarea textarea-xl editor-area" placeholder="记录作业内容、完成要求、截止时间..." value="{{homework}}" bindinput="onHomeworkInput" />
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">知识点</view>
          <input class="input" placeholder="如 导数与单调性" value="{{topic}}" bindinput="onTopicInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">本节学习知识点</view>
          <input class="input" placeholder="如 极值判定" value="{{learnedTopics}}" bindinput="onLearnedTopicsInput" />
        </view>
      </view>

      <view class="field">
        <view class="field-label">薄弱知识点（标签，逗号分隔）</view>
        <input class="input" placeholder="如 三角函数,数列" value="{{weakTopicsText}}" bindinput="onWeakTopicsInput" />
      </view>

      <view class="field">
        <view class="field-label">备注</view>
        <textarea class="textarea textarea-md" placeholder="其他补充说明" value="{{notes}}" bindinput="onNotesInput" />
      </view>
    </view>

    <view class="card preview-card mt-12">
      <view class="section-title">Markdown 预览</view>
      <view class="preview-block">
        <view class="preview-title">课程内容</view>
        <view class="preview-text">{{content || '（空）'}}</view>
      </view>
      <view class="preview-block">
        <view class="preview-title">学生情况</view>
        <view class="preview-text">{{studentPerformance || '（空）'}}</view>
      </view>
      <view class="preview-block">
        <view class="preview-title">课后作业</view>
        <view class="preview-text">{{homework || '（空）'}}</view>
      </view>
    </view>
  </view>

  <view class="action-bar">
    <view class="btn-primary" bindtap="saveLesson">{{isEditMode ? '保存修改' : '保存课程记录'}}</view>
  </view>

</view>

<canvas id="lessonShareCanvas" type="2d" class="share-canvas" style="width:720px;height:1420px;"></canvas>
