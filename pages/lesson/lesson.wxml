<view class="container">
  <view class="hero">
    <view class="hero-title">课程记录</view>
    <view class="hero-sub">按年级查看课程记录，并为指定学生新增课程记录。</view>
    <view class="chip-row">
      <view class="chip">年级 {{currentGrade}}</view>
      <view class="chip">记录 {{lessons.length}}</view>
    </view>
  </view>

  <view class="card" wx:if="{{fatalError}}">
    <view class="section-title">页面错误</view>
    <view class="sub">{{fatalError}}</view>
  </view>

  <view class="card" wx:if="{{!showCreatePanel}}">
    <view class="row">
      <view class="section-title" style="margin-bottom:0;">课程记录列表</view>
      <view class="btn-primary" style="height:66rpx;line-height:66rpx;padding:0 22rpx;" bindtap="toggleCreatePanel">新增课程记录</view>
    </view>
    <view class="mt-12">
      <picker mode="selector" range="{{grades}}" value="{{gradeIndex}}" bindchange="onGradeChange">
        <view class="picker">当前年级：{{currentGrade}}</view>
      </picker>
    </view>

    <view wx:if="{{!lessons.length}}" class="sub mt-12">暂无课程记录</view>
    <view wx:for="{{lessons}}" wx:key="id" class="list-item">
      <view class="row">
        <text>{{item.lessonDate}} · {{item.subject}}</text>
        <text class="badge">{{item.status}}</text>
      </view>
      <view class="sub mt-8">年级 {{item.grade}} · 学生 {{item.studentName || '未填'}} · 教师 {{item.teacher || '未填'}} · 时长 {{item.duration}} 分钟</view>
      <view class="sub">内容：{{item.content || '未填写'}}</view>
      <view class="sub">作业：{{item.homework || '未填写'}}</view>
    </view>
  </view>

  <view class="card" wx:else>
    <view class="row">
      <view class="section-title" style="margin-bottom:0;">新增课程记录</view>
      <view class="btn-ghost" style="height:66rpx;line-height:66rpx;padding:0 22rpx;" bindtap="toggleCreatePanel">返回列表</view>
    </view>
  </view>

  <view class="card" wx:if="{{showCreatePanel}}">
    <view class="section-title">课程信息</view>
    <view class="form-block">
      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">年级</view>
          <picker mode="selector" range="{{grades}}" value="{{gradeIndex}}" bindchange="onGradeChange">
            <view class="picker">{{currentGrade}}</view>
          </picker>
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">学生</view>
          <picker mode="selector" range="{{students}}" range-key="name" value="{{studentIndex}}" bindchange="onStudentChange">
            <view class="picker">{{currentStudentName}}</view>
          </picker>
        </view>
      </view>

      <view class="field">
        <view class="field-label">上课日期</view>
        <input class="input" placeholder="如 2026-03-03" value="{{lessonDate}}" bindinput="onDateInput" />
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">科目</view>
          <input class="input" placeholder="如 数学" value="{{subject}}" bindinput="onSubjectInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">授课老师</view>
          <input class="input" placeholder="老师姓名" value="{{teacher}}" bindinput="onTeacherInput" />
        </view>
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">时长（分钟）</view>
          <input class="input" type="number" placeholder="120" value="{{duration}}" bindinput="onDurationInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">课程状态</view>
          <picker mode="selector" range="{{lessonStatusOptions}}" value="{{lessonStatusIndex}}" bindchange="onStatusChange">
            <view class="picker">{{lessonStatusOptions[lessonStatusIndex]}}</view>
          </picker>
        </view>
      </view>

      <view class="field">
        <view class="field-label">出勤状态</view>
        <picker mode="selector" range="{{attendanceOptions}}" value="{{attendanceIndex}}" bindchange="onAttendanceChange">
          <view class="picker">{{attendance}}</view>
        </picker>
      </view>

      <view class="field">
        <view class="field-label">课程内容</view>
        <textarea class="textarea textarea-lg" placeholder="本节课重点内容（可记录知识点、授课过程、学生反馈）" value="{{content}}" bindinput="onContentInput" />
      </view>

      <view class="field">
        <view class="field-label">课后作业</view>
        <textarea class="textarea textarea-lg" placeholder="课后练习与作业安排（可分条记录）" value="{{homework}}" bindinput="onHomeworkInput" />
      </view>

      <view class="field">
        <view class="field-label">课堂评语</view>
        <textarea class="textarea textarea-md" placeholder="课堂评语（选填）" value="{{comment}}" bindinput="onCommentInput" />
      </view>
    </view>
  </view>

  <view class="action-bar" wx:if="{{showCreatePanel}}">
    <view class="btn-primary" bindtap="saveLesson">保存课程记录</view>
  </view>
</view>
