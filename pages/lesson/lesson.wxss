.table-filters {
  display: flex;
  gap: 12rpx;
}

.table-filters .input,
.table-filters .picker {
  margin-bottom: 0;
}

.filter-picker {
  min-width: 190rpx;
}

.action-btn {
  height: 66rpx;
  line-height: 66rpx;
  padding: 0 20rpx;
}

.lesson-item {
  background: linear-gradient(180deg, #fcfdff 0%, #f8faff 100%);
}

.lesson-title {
  font-weight: 700;
  color: #1f2937;
}

.op-row {
  display: flex;
  justify-content: flex-end;
  gap: 8rpx;
}

.op-btn {
  min-width: 44rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 12rpx;
  border: 1rpx solid;
  font-size: 22rpx;
  padding: 0 10rpx;
  font-weight: 700;
  background: #fff;
}

.op-view {
  color: #00a8f0;
  border-color: #00a8f0;
}

.op-edit {
  color: #4f46e5;
  border-color: #4f46e5;
}

.op-copy {
  color: #8b5cf6;
  border-color: #8b5cf6;
}

.op-img {
  color: #f59e0b;
  border-color: #f59e0b;
}

.op-del {
  color: #ef4444;
  border-color: #ef4444;
}

.editor-area {
  min-height: 300rpx;
}

.textarea-xl {
  min-height: 300rpx;
}

.preview-card {
  background: #f6f7ff;
  border: 1rpx solid #dce2fb;
  box-shadow: none;
  margin-bottom: 0;
}

.preview-block + .preview-block {
  margin-top: 14rpx;
}

.preview-title {
  font-size: 24rpx;
  color: #4338ca;
  font-weight: 700;
}

.preview-text {
  margin-top: 6rpx;
  color: #374151;
  line-height: 1.7;
  white-space: pre-wrap;
}

.share-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 720px;
  height: 1080px;
}
