.record-header {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-title {
  font-size: 56rpx;
  font-weight: 800;
  color: #0f172a;
}

.search-dot {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}

.record-time {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #94a3b8;
  letter-spacing: 1rpx;
}

.search-box {
  display: flex;
  gap: 10rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  margin-bottom: 0;
}

.export-btn {
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 20rpx;
}

.tabs-row {
  margin-top: 16rpx;
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.tab-item {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 700;
}

.tab-item.active {
  background: #6366f1;
  border-color: #6366f1;
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(99, 102, 241, 0.25);
}

.record-card {
  margin-top: 14rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 18rpx;
  border: 1rpx solid #eef2ff;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.08);
}

.card-top {
  align-items: flex-start;
}

.card-left {
  flex: 1;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #eef2ff 0%, #dbeafe 100%);
  color: #4f46e5;
  font-size: 30rpx;
  font-weight: 800;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.student-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #1f2937;
}

.subject-badge {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.subject-badge.math {
  background: #eef2ff;
  color: #4f46e5;
}

.subject-badge.other {
  background: #f3e8ff;
  color: #7e22ce;
}

.time-line {
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #94a3b8;
  font-weight: 700;
}

.status-badge {
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 20rpx;
  font-weight: 700;
}

.content-line {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.7;
}

.op-row {
  margin-top: 14rpx;
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
  border-top: 1rpx solid #f1f5f9;
  padding-top: 10rpx;
}

.icon-btn {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "SF Pro Text", "PingFang SC", "Helvetica Neue", sans-serif;
}

.icon-btn.edit {
  background: #e0f2fe;
  color: #0284c7;
}

.icon-btn.copy {
  background: #dcfce7;
  color: #16a34a;
}

.icon-btn.view {
  background: #f3e8ff;
  color: #7e22ce;
}

.icon-btn.img {
  background: #fff7ed;
  color: #ea580c;
}

.icon-btn.del {
  background: #ffe4e6;
  color: #e11d48;
}

.fab {
  position: fixed;
  right: 34rpx;
  bottom: 144rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #fff;
  font-size: 56rpx;
  line-height: 96rpx;
  text-align: center;
  box-shadow: 0 14rpx 32rpx rgba(99, 102, 241, 0.35);
  z-index: 20;
}

.empty {
  margin-top: 80rpx;
  text-align: center;
}

.empty-icon {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #eef2ff;
  color: #6366f1;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
}

.empty-text {
  margin-top: 14rpx;
  color: #94a3b8;
  font-size: 24rpx;
}

.action-btn {
  height: 66rpx;
  line-height: 66rpx;
  padding: 0 20rpx;
}

.editor-area {
  min-height: 300rpx;
}

.textarea-xl {
  min-height: 300rpx;
}

.preview-card {
  background: #f6f7ff;
  border: 1rpx solid #dce2fb;
  box-shadow: none;
  margin-bottom: 0;
}

.preview-block + .preview-block {
  margin-top: 14rpx;
}

.preview-title {
  font-size: 24rpx;
  color: #4338ca;
  font-weight: 700;
}

.preview-text {
  margin-top: 6rpx;
  color: #374151;
  line-height: 1.7;
  white-space: pre-wrap;
}

.share-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 720px;
  height: 1480px;
}
