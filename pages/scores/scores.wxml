<view class="container">
  <view class="hero">
    <view class="hero-title">学习进度</view>
    <view class="hero-sub">记录测验成绩、掌握程度与薄弱点，持续追踪学生学习状态。</view>
    <view class="chip-row">
      <view class="chip">记录 {{records.length}}</view>
      <view class="chip">薄弱点 {{weaknessStats.length}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">进度录入</view>
    <view class="form-block">
      <view class="field">
        <view class="field-label">学生</view>
        <picker mode="selector" range="{{students}}" range-key="name" value="{{studentIndex}}" bindchange="onStudentChange">
          <view class="picker">{{currentStudentName}}</view>
        </picker>
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">测验名称</view>
          <input class="input" placeholder="阶段测验/周测" value="{{form.examName}}" data-key="examName" bindinput="onFormInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">测验日期</view>
          <input class="input" placeholder="2026-03-03" value="{{form.examDate}}" data-key="examDate" bindinput="onFormInput" />
        </view>
      </view>

      <view class="field">
        <view class="field-label">掌握程度</view>
        <picker mode="selector" range="{{masteryOptions}}" value="{{masteryIndex}}" bindchange="onMasteryChange">
          <view class="picker">{{masteryOptions[masteryIndex]}}</view>
        </picker>
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">数学分</view>
          <input class="input" type="number" placeholder="0-150" value="{{form.math}}" data-key="math" bindinput="onFormInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">英语分</view>
          <input class="input" type="number" placeholder="0-150" value="{{form.english}}" data-key="english" bindinput="onFormInput" />
        </view>
      </view>

      <view class="row-2col">
        <view class="field" style="flex:1;">
          <view class="field-label">总分</view>
          <input class="input" type="number" placeholder="总分" value="{{form.total}}" data-key="total" bindinput="onFormInput" />
        </view>
        <view class="field" style="flex:1;">
          <view class="field-label">薄弱点标签</view>
          <picker mode="selector" range="{{tags}}" range-key="name" value="{{tagIndex}}" bindchange="onTagChange">
            <view class="picker">{{currentTagName}}</view>
          </picker>
        </view>
      </view>

      <view class="field">
        <view class="field-label">备注</view>
        <textarea class="textarea" placeholder="记录表现、错误原因、改进建议" value="{{form.comment}}" data-key="comment" bindinput="onFormInput" />
      </view>
    </view>
    <view class="action-bar">
      <view class="btn-primary" bindtap="saveExam">保存学习进度</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">薄弱点 Top5</view>
    <view wx:if="{{!weaknessStats.length}}" class="sub">暂无薄弱点数据</view>
    <view wx:for="{{weaknessStats}}" wx:key="tagId" class="list-item">
      <view class="row"><text>{{item.tagName}}</text><text class="badge">{{item.count}} 次</text></view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">最近进度记录</view>
    <view wx:if="{{!records.length}}" class="sub">暂无进度记录</view>
    <view wx:for="{{records}}" wx:key="id" class="list-item">
      <view class="row">
        <text>{{item.studentName}} · {{item.examName}}</text>
        <text class="badge">{{item.masteryLevel}}</text>
      </view>
      <view class="sub mt-8">{{item.examDate}} · 总分 {{item.totalScore}}（数学{{item.subjectScores.math}} / 英语{{item.subjectScores.english}}）</view>
      <view class="sub">{{item.comment || '无备注'}}</view>
    </view>
  </view>
</view>
