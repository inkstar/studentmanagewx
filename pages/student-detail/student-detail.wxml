<view class="container" wx:if="{{student}}">
  <view class="hero">
    <view class="hero-title">{{student.name}}</view>
    <view class="hero-sub">{{student.className}} · {{student.phone || '未填写手机号'}}</view>
    <view class="chip-row">
      <view class="chip">家长 {{student.guardian || '未填写'}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">薄弱点记录</view>
    <picker mode="selector" range="{{tags}}" range-key="name" value="{{tagIndex}}" bindchange="onTagChange">
      <view class="picker">标签：{{currentTagName}}</view>
    </picker>
    <textarea class="textarea" placeholder="备注（选填）" value="{{weaknessNote}}" bindinput="onWeaknessNoteInput" />
    <view class="btn-primary" bindtap="addWeakness">新增薄弱点</view>

    <view wx:if="{{!weaknessLogs.length}}" class="sub mt-12">暂无记录</view>
    <view wx:for="{{weaknessLogs}}" wx:key="id" class="list-item">
      <view class="row">
        <text>{{item.tagName}}</text>
        <text class="badge">{{item.sourceType}}</text>
      </view>
      <view class="sub mt-8">{{item.note || '无备注'}} · {{item.createdAt}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">考试记录</view>
    <view wx:if="{{!examRecords.length}}" class="sub">暂无考试记录</view>
    <view wx:for="{{examRecords}}" wx:key="id" class="list-item">
      <view class="row">
        <text>{{item.examName}}</text>
        <text class="badge">总分 {{item.totalScore}}</text>
      </view>
      <view class="sub mt-8">{{item.examDate}} · 数学{{item.subjectScores.math}} / 英语{{item.subjectScores.english}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">课堂记录</view>
    <view wx:if="{{!lessonRecords.length}}" class="sub">暂无课堂记录</view>
    <view wx:for="{{lessonRecords}}" wx:key="lessonId" class="list-item">
      <view class="row">
        <text>{{item.lessonDate}}</text>
        <text class="badge">{{item.attendance}}</text>
      </view>
      <view class="sub mt-8">{{item.content || '未填写课程内容'}}</view>
      <view class="sub">{{item.comment || '无课堂评语'}}</view>
    </view>
  </view>
</view>
