<view class="container">
  <view class="card">
    <view class="title">我的</view>
    <view class="sub">版本：{{version}}</view>
    <view class="sub">当前角色：{{runtime.role}}</view>
    <view class="sub">数据模式：{{runtime.dataMode}}</view>
  </view>

  <view class="card">
    <view class="title">运行配置</view>
    <view class="sub">可切换老师/管理员身份，预留云开发模式。</view>

    <picker mode="selector" range="{{roleOptions}}" value="{{roleIndex}}" bindchange="onRoleChange">
      <view class="picker">角色：{{roleOptions[roleIndex]}}</view>
    </picker>

    <picker mode="selector" range="{{modeOptions}}" value="{{modeIndex}}" bindchange="onModeChange">
      <view class="picker">数据模式：{{modeOptions[modeIndex]}}</view>
    </picker>

    <input class="input" placeholder="云开发环境ID（CLOUD模式可填）" value="{{runtime.envId}}" bindinput="onEnvIdInput" />
    <view class="row">
      <view class="btn-ghost" bindtap="saveEnvId">保存环境ID</view>
      <view class="btn-ghost" bindtap="checkCloudHealth">检测云函数</view>
    </view>
    <view class="sub mt-12">云状态：{{cloudStatus}}</view>
  </view>

  <view class="card" wx:if="{{stats}}">
    <view class="title">当前数据概览</view>
    <view class="sub">学生：{{stats.totalStudents}}</view>
    <view class="sub">课堂：{{stats.totalLessons}}</view>
    <view class="sub">本周考试：{{stats.weeklyExams}}</view>
    <view class="sub">薄弱点记录：{{stats.weaknessAlerts}}</view>
  </view>

  <view class="card">
    <view class="title">数据导出</view>
    <view class="sub">导出为 CSV 文本并复制到剪贴板，可直接粘贴到 Excel。</view>
    <view class="btn-ghost mt-12" bindtap="exportStudents">导出学生CSV</view>
    <view class="btn-ghost mt-12" bindtap="exportLessons">导出课堂CSV</view>
    <view class="btn-ghost mt-12" bindtap="exportExams">导出成绩CSV</view>
  </view>

  <view class="card">
    <view class="title">运维工具</view>
    <view class="sub">用于快速回到初始演示数据。</view>
    <view class="btn-ghost mt-12" bindtap="resetDemo">重置示例数据</view>
  </view>
</view>
