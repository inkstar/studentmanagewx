<view class="container">
  <view class="hero">
    <view class="hero-title">教学仪表盘</view>
    <view class="hero-sub">参考课程管理模板重构：聚合学生、课程、出勤率和学习进度分布。</view>
    <view class="chip-row">
      <view class="chip">学生 {{stats.totalStudents}}</view>
      <view class="chip">课程 {{stats.totalLessons}}</view>
      <view class="chip">出勤率 {{stats.attendanceRate}}%</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">核心统计</view>
    <view class="grid">
      <view class="stat">
        <view class="sub">学生总数</view>
        <view class="stat-num">{{stats.totalStudents}}</view>
      </view>
      <view class="stat">
        <view class="sub">课程记录</view>
        <view class="stat-num">{{stats.totalLessons}}</view>
      </view>
      <view class="stat">
        <view class="sub">本周进度</view>
        <view class="stat-num">{{stats.weeklyExams}}</view>
      </view>
      <view class="stat">
        <view class="sub">薄弱点记录</view>
        <view class="stat-num">{{stats.weaknessAlerts}}</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">掌握程度分布</view>
    <view class="kv"><view class="kv-key">优秀</view><view class="kv-value">{{progressDistribution.excellent}}</view></view>
    <view class="kv"><view class="kv-key">良好</view><view class="kv-value">{{progressDistribution.good}}</view></view>
    <view class="kv"><view class="kv-key">一般</view><view class="kv-value">{{progressDistribution.fair}}</view></view>
    <view class="kv"><view class="kv-key">薄弱</view><view class="kv-value">{{progressDistribution.weak}}</view></view>
  </view>

  <view class="card" wx:if="{{latestLesson}}">
    <view class="section-title">最近课程</view>
    <view class="kv"><view class="kv-key">日期</view><view class="kv-value">{{latestLesson.lessonDate}}</view></view>
    <view class="kv"><view class="kv-key">主题</view><view class="kv-value">{{latestLesson.content || '未填写'}}</view></view>
    <view class="kv"><view class="kv-key">出勤/迟到/缺勤</view><view class="kv-value">{{latestLesson.present}} / {{latestLesson.late}} / {{latestLesson.absent}}</view></view>
  </view>
</view>
