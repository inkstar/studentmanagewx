<view class="container dashboard-page">
  <view class="dashboard-header">
    <view>
      <view class="dash-title">仪表盘</view>
      <view class="dash-time">更新时间: {{updatedAt}}</view>
    </view>
    <view class="profile-dot-wrap">
      <view class="profile-dot"></view>
      <view class="profile-online"></view>
    </view>
  </view>

  <view class="dash-grid">
    <view class="dash-stat dash-indigo" bindtap="goStudents">
      <view class="dash-icon">学生</view>
      <view class="dash-num">{{stats.totalStudents}}</view>
      <view class="dash-label">学生总数</view>
    </view>
    <view class="dash-stat dash-blue" bindtap="goLessons">
      <view class="dash-icon">课程</view>
      <view class="dash-num">{{stats.totalLessons}}</view>
      <view class="dash-label">总课程数</view>
    </view>
    <view class="dash-stat dash-purple" bindtap="goLessons">
      <view class="dash-icon">反馈</view>
      <view class="dash-num">{{completedLessons}}</view>
      <view class="dash-label">已完成反馈</view>
    </view>
    <view class="dash-stat dash-deep" bindtap="goScores">
      <view class="dash-icon">计划</view>
      <view class="dash-num">{{thisMonthLessons}}</view>
      <view class="dash-label">本月计划</view>
    </view>
  </view>

  <view class="card dashboard-card">
    <view class="row">
      <view class="section-title" style="margin-bottom:0;">反馈率统计</view>
      <view class="rate-tag {{attendanceRate >= 80 ? 'good' : 'warn'}}">{{attendanceRate >= 80 ? '良好' : '待提升'}}</view>
    </view>
    <view class="ring-wrap">
      <view class="ring-value">{{attendanceRate}}%</view>
      <view class="ring-sub">完成比</view>
    </view>
    <view class="progress-track mt-12">
      <view class="progress-fill" style="width: {{attendanceRate}}%;"></view>
    </view>
  </view>

  <view class="card dashboard-card">
    <view class="row">
      <view class="section-title" style="margin-bottom:0;">学生进度分布</view>
      <view class="sub">{{stats.totalStudents}} 人</view>
    </view>
    <view class="dist-list">
      <view class="dist-item" wx:for="{{distribution}}" wx:key="name">
        <view class="row">
          <view class="dist-name">{{item.name}}</view>
          <view class="dist-count">{{item.count}} 人</view>
        </view>
        <view class="dist-track">
          <view class="dist-fill" style="width: {{item.percent}}%; background: {{item.color}};"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="card recent-card">
    <view class="row">
      <view class="section-title" style="margin-bottom:0;">最近课程反馈</view>
      <view class="recent-link" bindtap="goLessons">查看全部</view>
    </view>
    <view class="recent-inner" bindtap="goLessons">
      <view class="row">
        <view>
          <view class="recent-name">{{latestLesson ? (latestLesson.classId || '最近课程') : '暂无记录'}}</view>
          <view class="recent-date">{{latestLesson ? latestLesson.lessonDate : '-'}}</view>
        </view>
        <view class="recent-badge">最近</view>
      </view>
      <view class="recent-content">{{latestLesson ? (latestLesson.content || '还没有课程反馈记录，快去新增一条吧！') : '还没有课程反馈记录，快去新增一条吧！'}}</view>
    </view>
  </view>
</view>
