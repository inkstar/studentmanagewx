.dashboard-page {
  padding-bottom: 24rpx;
}

.dashboard-header {
  padding: 10rpx 4rpx 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dash-title {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: 0.5rpx;
  color: #0f172a;
}

.dash-time {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #64748b;
}

.profile-dot-wrap {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.profile-dot {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #6366f1;
}

.profile-online {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #22c55e;
  border: 2rpx solid #fff;
}

.dash-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.dash-stat {
  border-radius: 24rpx;
  padding: 20rpx;
  color: #fff;
  box-shadow: 0 14rpx 28rpx rgba(99, 102, 241, 0.24);
}

.dash-indigo {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
}

.dash-blue {
  background: linear-gradient(135deg, #3b82f6 0%, #4f46e5 100%);
}

.dash-purple {
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
}

.dash-deep {
  background: linear-gradient(135deg, #4338ca 0%, #1d4ed8 100%);
}

.dash-icon {
  font-size: 20rpx;
  opacity: 0.9;
}

.dash-num {
  margin-top: 8rpx;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1;
}

.dash-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.92;
}

.dashboard-card {
  margin-top: 16rpx;
}

.rate-tag {
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.rate-tag.good {
  background: #dcfce7;
  color: #15803d;
}

.rate-tag.warn {
  background: #ffedd5;
  color: #c2410c;
}

.ring-wrap {
  margin-top: 16rpx;
  border-radius: 18rpx;
  background: #f8faff;
  border: 1rpx solid #e4e9fd;
  padding: 24rpx;
  text-align: center;
}

.ring-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #4338ca;
}

.ring-sub {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #64748b;
  letter-spacing: 1rpx;
}

.progress-track {
  width: 100%;
  height: 14rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #10b981 0%, #22c55e 100%);
  border-radius: 999rpx;
}

.dist-list {
  margin-top: 12rpx;
}

.dist-item + .dist-item {
  margin-top: 16rpx;
}

.dist-name {
  font-size: 22rpx;
  color: #475569;
}

.dist-count {
  font-size: 22rpx;
  font-weight: 700;
  color: #0f172a;
}

.dist-track {
  margin-top: 8rpx;
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  overflow: hidden;
}

.dist-fill {
  height: 100%;
  border-radius: 999rpx;
}

.recent-card {
  margin-top: 16rpx;
  background: #eef2ff;
  border-color: #dbe1ff;
}

.recent-link {
  font-size: 22rpx;
  color: #4f46e5;
  font-weight: 700;
}

.recent-inner {
  margin-top: 10rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 16rpx;
}

.recent-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.recent-date {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #64748b;
}

.recent-badge {
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 700;
  background: #eef2ff;
  color: #4f46e5;
}

.recent-content {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #475569;
  line-height: 1.6;
}
